{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets|downloads|headshot|favicon).*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/tt",
      "destination": "/?utm_source=tiktok&utm_medium=bio&utm_campaign=cohort1",
      "permanent": false
    },
    {
      "source": "/ig",
      "destination": "/?utm_source=instagram&utm_medium=bio&utm_campaign=cohort1",
      "permanent": false
    },
    {
      "source": "/fb",
      "destination": "/?utm_source=facebook&utm_medium=profile&utm_campaign=cohort1",
      "permanent": false
    },
    {
      "source": "/tt-c",
      "destination": "/coaching?utm_source=tiktok&utm_medium=bio&utm_campaign=cohort1",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/drip-cron",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/drip-cron",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/drip-cron",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/drip-cron",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/postiz-cron",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cohort-saturday-cron",
      "schedule": "0 12 16 5 *"
    },
    {
      "path": "/api/cohort-sunday-cron",
      "schedule": "0 13 17 5 *"
    },
    {
      "path": "/api/reply-agent",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/buyer-upsell-cron",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/diagnostic-drip-cron",
      "schedule": "0 14 * * *"
    }
  ]
}
